{
  "name": "@tessera-ui/core",
  "version": "0.1.0",
  "description": "Framework-agnostic web component library built with Stencil",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/tessera-ui/tessera-ui.esm.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "build.watch": "stencil build --watch --serve",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec",
    "test.watch": "stencil test --spec --watchAll",
    "test.e2e": "stencil test --e2e",
    "test.all": "stencil test --spec --e2e",
    "generate": "stencil generate",
    "generate:react": "stencil build --docs-json dist/components.json && node scripts/generate-react.js",
    "generate:vue": "stencil build --docs-json dist/components.json && node scripts/generate-vue.js",
    "generate:angular": "stencil build --docs-json dist/components.json && node scripts/generate-angular.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint.fix": "eslint src --ext .ts,.tsx --fix",
    "tokens:build": "node scripts/build-tokens.js"
  },
  "devDependencies": {
    "@stencil/core": "^4.22.0",
    "@stencil/react-output-target": "^0.7.1",
    "@stencil/vue-output-target": "^0.8.9",
    "@stencil/angular-output-target": "^0.9.0",
    "@stencil/sass": "^3.0.12",
    "@storybook/html": "^8.4.0",
    "@storybook/html-vite": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-a11y": "^8.4.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "playwright": "^1.48.0",
    "typescript": "^5.6.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "prettier": "^3.3.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/tessera-ui"
  },
  "keywords": [
    "web-components",
    "stencil",
    "component-library",
    "design-system",
    "react",
    "vue",
    "angular",
    "framework-agnostic"
  ]
}
