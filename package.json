{
  "name": "@tessera-ui/core",
  "version": "0.6.0",
  "description": "Framework-agnostic web component library built with Stencil",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/tessera-ui/tessera-ui.esm.js",
  "files": [
    "dist/",
    "loader/",
    "!dist/**/*.map",
    "!dist/**/*.stories.js",
    "!dist/**/*.stories.d.ts",
    "!dist/components.json"
  ],
  "sideEffects": [
    "**/*.css",
    "dist/tessera-ui/tessera-ui.esm.js"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "_comment_dist_glob": "Required: framework wrappers (react/vue/angular) import from @tessera-ui/core/dist/. Removing this breaks all wrapper packages.",
    "./dist/*": "./dist/*",
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js",
      "types": "./loader/index.d.ts"
    }
  },
  "scripts": {
    "build": "stencil build && node scripts/post-build.js",
    "build.watch": "stencil build --watch",
    "start": "stencil build && concurrently \"stencil build --watch\" \"storybook dev -p 6006 --ci\" --names stencil,storybook --prefix-colors blue,magenta",
    "test": "stencil test --spec",
    "test.watch": "stencil test --spec --watchAll",
    "test.e2e": "stencil test --e2e",
    "test.all": "stencil test --spec --e2e",
    "generate": "stencil generate",
    "generate:react": "stencil build --docs-json dist/components.json && node scripts/generate-react.js",
    "generate:vue": "stencil build --docs-json dist/components.json && node scripts/generate-vue.js",
    "generate:angular": "stencil build --docs-json dist/components.json && node scripts/generate-angular.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs": "stencil build && pnpm -C docs dev",
    "docs:build": "stencil build && pnpm -C docs build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint.fix": "eslint src --ext .ts,.tsx --fix",
    "tokens:build": "node scripts/build-tokens.js",
    "version:bump": "lerna version --no-push --yes",
    "publish:packages": "pnpm build && pnpm -r --filter='!@tessera-ui/docs' run build && pnpm -r --filter='!@tessera-ui/docs' publish --access public --no-git-checks"
  },
  "dependencies": {
    "lucide": "^0.511.0"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^1.3.0",
    "@stencil/core": "^4.43.3",
    "@stencil/react-output-target": "^1.4.2",
    "@stencil/sass": "^3.2.3",
    "@stencil/vue-output-target": "^0.13.1",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/html": "^10.3.1",
    "@storybook/html-vite": "^10.3.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "lerna": "^9.0.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "puppeteer": "^20.9.0",
    "storybook": "^10.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jkguidaven/tessera-ui"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "puppeteer",
      "sharp"
    ]
  },
  "keywords": [
    "web-components",
    "stencil",
    "component-library",
    "design-system",
    "react",
    "vue",
    "angular",
    "framework-agnostic"
  ]
}
