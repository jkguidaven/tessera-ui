{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "0.5.0",
  "npmClient": "pnpm",
  "command": {
    "version": {
      "message": "chore(release): publish %s",
      "allowBranch": "main"
    },
    "publish": {
      "access": "public"
    }
  },
  "packages": [".", "packages/*"]
}
