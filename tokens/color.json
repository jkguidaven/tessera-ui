      "success-bg":      { "$value": "rgba(72, 199, 142, 0.08)",  "$type": "color", "$description": "Success feedback background" },
      "success-border":  { "$value": "rgba(72, 199, 142, 0.25)",  "$type": "color", "$description": "Success feedback border" },
