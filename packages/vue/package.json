{
  "name": "@tessera-ui/vue",
  "version": "0.6.3",
  "description": "Tessera UI components for Vue",
  "main": "dist/cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": [
    "**/*.css",
    "./dist/index.js",
    "./dist/cjs/index.js"
  ],
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json"
  },
  "dependencies": {
    "@stencil/vue-output-target": "^0.13.1",
    "@tessera-ui/core": "workspace:^"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vue": "^3.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jkguidaven/tessera-ui",
    "directory": "packages/vue"
  },
  "license": "MIT"
}
